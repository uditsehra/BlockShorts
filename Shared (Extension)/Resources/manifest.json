{
    "manifest_version": 3,
    "default_locale": "en",

    "name": "Block Shorts",
    "version": "1.0",
    "description": "Safari Extension to block annoying and distracting youtube shorts.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "tabs"
    ],
    "host_permissions": ["*://www.youtube.com/*"],
    "content_scripts":[
        {
            "matches": ["*://www.youtube.com/*"],
            "js": ["content.js"],
            "run_at": "document_end"
        }
    ],

    "icons": {
        "48": "images/icon-48.png",
        "64": "images/icon-64.png",
        "128": "images/icon-128.png",
        "256": "images/icon-256.png",
        "512": "images/icon-512.png"
    },

    "background": {
        "service_worker": "background.js",
        "type": "module"
    },

    "action": {
        "default_popup": "popup.html",
        "default_icon": "images/toolbar-icon.svg"
    }
}
