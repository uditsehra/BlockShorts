{
    "manifest_version": 3,
    "name": "Block Shorts",
    "version": "1.0",
    "description": "Safari Extension to Youtube Block Shorts",
    "permissions": ["storage"],
    "host_permissions": ["*://*.youtube.com/*"],
    "content_scripts": [{
        "matches": ["*://*.youtube.com/*"],
        "js": ["content.js"],
        "run_at": "document_start"
    }],
    "background": { "service_worker": "background.js" },
    "action": {
        "default_popup": "popup.html"
    }
}
